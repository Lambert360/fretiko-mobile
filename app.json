{
  "expo": {
    "name": "fretiko-mobile",
    "slug": "fretiko-mobile",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/horse.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "fretiko",
    "splash": {
      "image": "./assets/horse.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kinging.fretikomobile",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to the camera to take photos, videos, and for video calls.",
        "NSPhotoLibraryUsageDescription": "Fretiko uses your photo library to upload product images, share posts, send photos in chat, and set profile pictures.",
        "NSMicrophoneUsageDescription": "This app needs access to the microphone for video calls and real-time voice conversations with Iko AI.",
        "NSUserNotificationsUsageDescription": "This app needs access to send you notifications about orders, messages, deliveries, and other important updates.",
        "UIBackgroundModes": [
          "audio",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/horse.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "blockedPermissions": [
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "versionCode": 3,
      "package": "com.kinging.fretikomobile",
      "googleServicesFile": "./google-services.json",
      "useNextNotificationsApi": true
    },
    "notification": {
      "icon": "./assets/horse.png",
      "color": "#3498DB",
      "iosDisplayInForeground": true,
      "androidMode": "default",
      "androidCollapsedTitle": "#{unread_notifications} new notifications"
    },
    "assets": [
      "./assets/sounds/cheer.MP3",
      "./assets/sounds/clapping.MP3",
      "./assets/sounds/crowd_sound.MP3",
      "./assets/sounds/gavel.MP3",
      "./assets/sounds/laugh.MP3",
      "./assets/sounds/notification_sound.MP3",
      "./assets/sounds/timer.MP3",
      "./assets/sounds/winner1.MP3",
      "./assets/sounds/winner2.MP3"
    ],
    "plugins": [
      "expo-secure-store",
      "expo-audio",
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to take photos and videos for video calls.",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for video calls and real-time voice conversations with Iko AI.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/horse.png",
          "color": "#3498DB",
          "sounds": [
            "./assets/sounds/notification_sound.MP3"
          ],
          "mode": "production"
        }
      ],
      "expo-font",
      "expo-maps"
    ],
    "extra": {
      "eas": {
        "projectId": "81969c14-245c-442b-9a46-ce19211e1c8e"
      },
      "apiUrl": "https://fretiko-backend.onrender.com"
    }
  }
}
