# =============================================================================
# Supabase Configuration (REQUIRED)
# These values should come from your Supabase project settings
# Get them from: https://app.supabase.com/project/_/settings/api
# =============================================================================

# Supabase Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon/Public Key (safe to expose in client-side code)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# API Configuration
# =============================================================================

# Backend API Base URL
EXPO_PUBLIC_API_URL=https://your-backend.com

# =============================================================================
# Real-time WebSocket Configuration
# =============================================================================

EXPO_PUBLIC_WS_URL=wss://your-backend.com

# =============================================================================
# Agora Live Streaming (Optional - for video calls)
# =============================================================================

EXPO_PUBLIC_AGORA_APP_ID=your-agora-app-id

# =============================================================================
# File Upload Configuration
# =============================================================================

EXPO_PUBLIC_MAX_FILE_SIZE=50MB
